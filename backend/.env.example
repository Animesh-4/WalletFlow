# ============================================================================
# WalletFlow Backend - Development Environment Configuration
# ============================================================================
# This is the configuration for LOCAL DEVELOPMENT.
# For production, see .env.production
# ============================================================================

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Database Configuration (Neon DB for Development)
# ============================================================================
# Set this to a DEVELOPMENT database only
# This allows you to freely test, seed, and reset data without affecting production
#
# Example Neon Development URL format:
# postgres://dev_user:dev_password@dev-region.neon.tech/walletflow_dev?sslmode=require
#
# Steps to get a Neon dev database:
# 1. Go to https://console.neon.tech
# 2. Create a new project (or use existing "development" project)
# 3. Copy the connection string for the "neon" role
# 4. Paste it below as DATABASE_URL
#
DATABASE_URL=postgres://[dev_user]:[dev_password]@[dev_hostname]/[dev_dbname]?sslmode=require

# ============================================================================
# JWT Authentication
# ============================================================================
# For development, you can use the default value below
# For production, you MUST generate a strong random secret (see .env.production)
#
JWT_SECRET=asqswfved1652e627dg3d2fd6273dgwe
JWT_EXPIRES_IN=24h

# ============================================================================
# Email Service - For Testing Invitations & Password Resets (Optional)
# ============================================================================
# In development, email is optional. The app will log email content to console
# if these are not configured.
#
# Option 1: Connect to a real email service for testing
# EMAIL_USER=your_development_email@example.com
# EMAIL_PASS=your_app_specific_password
#
# Option 2: Use Brevo SMTP for testing
# EMAIL_USER=your_test_sender@brevo.com
# EMAIL_PASS=your_brevo_smtp_key
#
# Leave commented out = emails logged to console during development
# EMAIL_USER=your_email@example.com
# EMAIL_PASS=your_app_specific_password
# EMAIL=noreply@localhost:3000

# ============================================================================
# Development Tips
# ============================================================================
#
# 1. Database Setup
#    - Create TWO separate projects in Neon: one for development, one for production
#    - Use DATABASE_URL from dev project for local development
#    - This prevents accidentally modifying production data
#
# 2. Running the Application
#    npm run dev          # Start development server with hot-reload
#    npm run db:seed      # Seed development database with default categories
#    npm run db:push      # Sync schema changes to development database
#
# 3. Testing Email
#    - Leave EMAIL_USER/EMAIL_PASS commented to see emails logged to console
#    - Or configure real credentials to actually send test emails
#
# 4. Never use production values here
#    - Don't commit production secrets to this file
#    - Keep this file for development/testing only
#    - Use .env.production for production configuration
#
# ============================================================================